# ============================================================
#  PerFin AI — Backend Environment Variables
#  Copy this file to .env and fill in your keys.
#  NEVER commit .env to git. (.env.example is safe to commit)
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ── MongoDB ─────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Clusters → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net
MONGODB_URI=

# MongoDB database name (will be created automatically)
MONGO_URI=
MONGO_DB=perfin

# ── JWT Authentication ───────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Resend (Email / OTP) ─────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=

# ── Google Gemini AI ─────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Groq AI ──────────────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=
